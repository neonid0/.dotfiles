{
    "title": "Custom Lock Screen Shortcut",
    "rules": [
        {
            "description": "Map Shift + Option + G to Lock Screen",
            "manipulators": [
                {
                    "type": "basic",
                    "from": {
                        "key_code": "g",
                        "modifiers": {
                            "mandatory": [
                                "left_shift",
                                "left_option"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "q",
                            "modifiers": [
                                "left_control",
                                "left_command"
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}
